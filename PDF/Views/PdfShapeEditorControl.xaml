<UserControl x:Class="PDF.Views.PdfShapeEditorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:c="clr-namespace:YukkuriMovieMaker.Controls;assembly=YukkuriMovieMaker.Controls"
             xmlns:vm="clr-namespace:PDF.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="50" d:DesignWidth="300"
             d:DataContext="{d:DesignInstance Type=vm:PdfShapeEditorViewModel}">
    <Grid>
        <c:PropertiesEditor Target="{Binding SelectedTarget}" BeginEdit="PropertiesEditor_BeginEdit" EndEdit="PropertiesEditor_EndEdit" />
    </Grid>
</UserControl>
